PORT=3000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/oraia?retryWrites=true&w=majority

JWT_SECRET=change-me-min-32-chars-long-secret
ENCRYPTION_KEY=change-me-32-char-minimum-key!!

GHL_CLIENT_ID=
GHL_APP_ID=
GHL_CLIENT_SECRET=
GHL_COMPANY_ID=
# Seed tokens via `npm run seed` — not loaded on server boot (avoids overwriting OAuth-refreshed tokens)
GHL_COMPANY_ACCESS_TOKEN=
GHL_COMPANY_REFRESH_TOKEN=

# GHL API requires this header on every request
GHL_API_VERSION=2021-07-28
# Only needed when API is deployed (production OAuth callback)
# GHL_OAUTH_REDIRECT_URI=https://your-api.com/api/oauth/callback

# Webhook auth — prefer GHL signature keys from marketplace app settings
WEBHOOK_SIGNATURE_PUBLIC_KEY=
WEBHOOK_PUBLIC_KEY=
# Legacy shared-secret header fallback (x-ghl-webhook-secret)
GHL_WEBHOOK_SECRET=

# Comma-separated CORS origins for production (empty = deny cross-origin)
# CORS_ALLOWED_ORIGINS=https://admin.example.com

# Push notifications (Expo). Set PUSH_NOTIFICATIONS_ENABLED=false to disable sending.
PUSH_NOTIFICATIONS_ENABLED=true

BOOTSTRAP_ADMIN_EMAIL=admin@oraiacrm.com
# Set a strong password before first deploy
BOOTSTRAP_ADMIN_PASSWORD=
